DATABASE_URL="postgresql://user:password@host:5432/database?schema=conductor_app"
# For hosted Postgres providers using TLS, prefer:
# DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=verify-full&schema=conductor_app"

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=admin@example.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=admin@example.com

# Optional shared token for MCP/VS Code event reporting
SKILL_EVENTS_TOKEN=replace-with-a-shared-token

# Optional. When true, conductor skill preview reads are logged as skill:preview.
ENABLE_SKILL_PREVIEW_TRACKING=false

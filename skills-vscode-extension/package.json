{
  "name": "skills-library",
  "displayName": "Skills Library",
  "description": "Browse and insert your personal SKILL.md library directly into the editor.",
  "version": "1.0.0",
  "publisher": "local",
  "type": "module",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.cjs",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "skillsLibrary",
          "title": "Skills Library",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "skillsLibrary": [
        {
          "id": "skillsLibrary.tree",
          "name": "Skills",
          "contextualTitle": "Skills Library"
        }
      ]
    },
    "commands": [
      {
        "command": "skillsLibrary.refresh",
        "title": "Skills: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "skillsLibrary.preview",
        "title": "Skills: Preview"
      },
      {
        "command": "skillsLibrary.insert",
        "title": "Skills: Insert at Cursor",
        "icon": "$(insert)"
      },
      {
        "command": "skillsLibrary.setSkillsPath",
        "title": "Skills: Set Skills Folder Location"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "skillsLibrary.refresh",
          "when": "view == skillsLibrary.tree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "skillsLibrary.insert",
          "when": "view == skillsLibrary.tree && viewItem == skill",
          "group": "inline"
        },
        {
          "command": "skillsLibrary.preview",
          "when": "view == skillsLibrary.tree",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Skills Library",
      "properties": {
        "skillsLibrary.skillsPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to your skills/ folder (the same folder used by SKILLS_PATH for the skills-mcp-server)."
        },
        "skillsLibrary.conductorUrl": {
          "type": "string",
          "default": "",
          "description": "Optional base URL for the conductor app. When set, preview/insert/file-change events are reported to /api/skill-events."
        },
        "skillsLibrary.userId": {
          "type": "string",
          "default": "",
          "description": "Optional user id sent to the conductor app in skill event headers."
        },
        "skillsLibrary.userEmail": {
          "type": "string",
          "default": "",
          "description": "Optional user email sent to the conductor app in skill event headers."
        },
        "skillsLibrary.userName": {
          "type": "string",
          "default": "",
          "description": "Optional user display name saved in the conductor app when skill events are reported."
        },
        "skillsLibrary.eventToken": {
          "type": "string",
          "default": "",
          "description": "Optional bearer token for reporting skill events to the conductor app."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.cjs --external:vscode --format=cjs --platform=node --target=node18",
    "watch": "npm run build -- --watch",
    "compile-check": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2"
  }
}

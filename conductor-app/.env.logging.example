# Environment Variables Template for Logging & Notifications

# Database (Required)
DATABASE_URL=postgresql://username:password@localhost:5432/conductor_db

# Email Service (Optional - logging works without email)
# Leave these commented out if you don't want to send emails

# Gmail Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# FROM_EMAIL=your-email@gmail.com

# AWS SES Configuration
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your-ses-username
# SMTP_PASSWORD=your-ses-password
# FROM_EMAIL=verified-email@yourcompany.com

# Other Mailbox Services
# SMTP_HOST=smtp.mailbox.com
# SMTP_PORT=587
# SMTP_USER=username
# SMTP_PASSWORD=password
# FROM_EMAIL=noreply@yourcompany.com

# Optional token for VS Code/MCP skill event reporting
# SKILL_EVENTS_TOKEN=replace-with-a-shared-token

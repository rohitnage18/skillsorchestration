DATABASE_URL="postgresql://postgres:postgres@localhost:5432/conductor?schema=conductor_app"

# Auth.js / NextAuth settings
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-secret
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=false
ALLOW_FIRST_USER_ADMIN=false

# Add comma-separated admin emails. In production, only these emails are auto-admin.
ADMIN_EMAILS=admin@example.com

# Google OAuth, optional
# GOOGLE_CLIENT_ID=replace-with-google-client-id
# GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# GitHub OAuth, optional
# GITHUB_CLIENT_ID=replace-with-github-client-id
# GITHUB_CLIENT_SECRET=replace-with-github-client-secret

# Optional SMTP settings for admin notification emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# FROM_EMAIL=your-email@gmail.com

# Required token for VS Code/MCP skill event reporting.
# Production requires a non-placeholder value with at least 32 characters.
SKILL_EVENTS_TOKEN=replace-with-a-shared-token

{
  "name": "skills-conductor-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:local": "powershell -NoProfile -Command \"$env:AUTH_URL='http://localhost:3000'; $env:AUTH_TRUST_HOST='true'; npm.cmd run dev\"",
    "prebuild": "prisma generate",
    "build": "next build",
    "start": "next start",
    "start:local": "powershell -NoProfile -Command \"$env:AUTH_URL='https://localhost:3000'; $env:AUTH_TRUST_HOST='true'; $env:SKILL_EVENTS_TOKEN='localdevskilltoken1234567890abcdef'; $env:SKILL_EVENTS_HMAC_SECRET='localdevhmackey1234567890abcdef'; npm.cmd start\"",
    "test": "node --experimental-strip-types --test --test-concurrency=1 tests/**/*.test.mjs",
    "demo:seed": "node scripts/seed-demo-data.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@xyflow/react": "^12.11.1",
    "next": "^16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.20"
  }
}
